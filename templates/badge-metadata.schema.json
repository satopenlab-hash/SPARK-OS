{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openlab-os/templates/badge-metadata.schema.json",
  "title": "OpenLab Recognition Record",
  "description": "Structural contract for recognition/badge records issued under templates/badge-metadata-template.json. Checks structure and the repo's non-negotiable red lines (no tradable/tokenized recognition, no public PII). It does not and cannot judge whether the underlying learning evidence is sound — that stays a human decision (see CLAUDE.md, Non-negotiable 6).",
  "type": "object",
  "required": [
    "type", "status", "title", "description", "issuedBy", "subject",
    "criteria", "evidence", "review", "aiAssistance", "financialization", "privacy"
  ],
  "properties": {
    "type": { "const": "OpenLabRecognitionRecord" },
    "status": {
      "type": "string",
      "enum": ["Genesis", "Pilot", "Validated", "Reference", "Certified"]
    },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "issuedBy": {
      "type": "object",
      "required": ["name", "role"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 }
      }
    },
    "subject": {
      "type": "object",
      "required": ["type", "publicIdentifier"],
      "properties": {
        "type": { "type": "string", "minLength": 1 },
        "publicIdentifier": { "type": "string", "minLength": 1 }
      }
    },
    "criteria": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["label", "url", "privacy"],
        "properties": {
          "label": { "type": "string", "minLength": 1 },
          "url": { "type": "string", "minLength": 1 },
          "privacy": { "type": "string", "enum": ["private", "public"] }
        }
      }
    },
    "review": {
      "type": "object",
      "required": ["reviewer", "decision", "date", "limitations"],
      "properties": {
        "reviewer": { "type": "string", "minLength": 1 },
        "decision": { "type": "string", "enum": ["approved", "revise", "not-yet"] },
        "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "limitations": { "type": "array", "items": { "type": "string" } }
      }
    },
    "aiAssistance": {
      "type": "object",
      "required": ["used", "disclosure"],
      "properties": {
        "used": { "type": "boolean" },
        "disclosure": { "type": "string" }
      }
    },
    "financialization": {
      "type": "object",
      "required": ["tradable", "tokenized"],
      "properties": {
        "tradable": { "const": false },
        "tokenized": { "const": false }
      }
    },
    "privacy": {
      "type": "object",
      "required": ["containsPII", "publicShareable"],
      "properties": {
        "containsPII": { "type": "boolean" },
        "publicShareable": { "type": "boolean" }
      },
      "if": { "properties": { "containsPII": { "const": true } } },
      "then": { "properties": { "publicShareable": { "const": false } } }
    }
  }
}
